{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RPG Platform Engine",
  "version": "0.1.0",
  "identifier": "com.mac2394q02.rpgplatform",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RPG Platform Engine",
        "width": 1600,
        "height": 920,
        "minWidth": 390,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}