{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for RPG Platform Engine",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$DOCUMENT/RPG Platform Engine/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$DOCUMENT/RPG Platform Engine/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$DOCUMENT/RPG Platform Engine/**" }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "$DOCUMENT/RPG Platform Engine/**" }]
    },
    "store:default"
  ]
}
