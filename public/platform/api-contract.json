{
  "schemaVersion": 1,
  "environment": "local",
  "transport": "local HTTP backend + JSON database on disk",
  "basePath": "http://127.0.0.1:8787/api",
  "updatedAt": "2026-07-17",
  "authHeader": "Authorization: Bearer <session-id>",
  "permissions": {
    "public": ["GET /games", "GET /maps", "GET /metadata", "GET /news", "GET /notifications", "GET /games/:gameId/playable/summary", "GET /games/:gameId/playable/:catalog", "GET /games/:gameId/playable/:catalog/:itemId", "GET /games/:gameId/playable/:catalog/:itemId/detail-pack", "POST /support/public"],
    "authenticated": ["POST /audit", "POST /chat/rooms/:roomId/channels/:channelId/messages"],
    "selfOrAdmin": ["PATCH /users/:userId", "GET /users/:userId/saves", "PATCH /users/:userId/saves/:saveId", "PATCH /support/tickets/:ticketId"],
    "admin": ["PATCH /games/:gameId", "PATCH /maps/:mapId", "PATCH /metadata", "PATCH /games/:gameId/playable/:catalog/:itemId", "PATCH /games/:gameId/playable/:catalog/:itemId/assets", "GET /games/:gameId/playable/export", "POST /games/:gameId/playable/import", "POST /news", "PATCH /news/:newsId", "DELETE /news/:newsId", "POST /notifications", "PATCH /notifications/:notificationId", "DELETE /notifications/:notificationId", "GET /audit", "GET /backup/export", "POST /backup/import"]
  },
  "modules": {
    "auth": {
      "login": "POST /auth/login",
      "logout": "POST /auth/sessions/:sessionId/logout",
      "refresh": "POST /auth/sessions/:sessionId/refresh",
      "passwordReset": "POST /auth/password-reset"
    },
    "users": {
      "list": "GET /users",
      "save": "PATCH /users/:userId",
      "block": "POST /users/:userId/block"
    },
    "games": {
      "list": "GET /games",
      "save": "PATCH /games/:gameId"
    },
    "maps": {
      "list": "GET /maps?gameId=:gameId",
      "detail": "GET /maps/:mapId",
      "save": "PATCH /maps/:mapId",
      "export": "GET /maps/:mapId/export",
      "import": "POST /maps/import"
    },
    "playable": {
      "summary": "GET /games/:gameId/playable/summary",
      "listCatalog": "GET /games/:gameId/playable/:catalog?limit=:limit&offset=:offset&q=:search",
      "detail": "GET /games/:gameId/playable/:catalog/:itemId",
      "detailPack": "GET /games/:gameId/playable/:catalog/:itemId/detail-pack",
      "saveDetail": "PATCH /games/:gameId/playable/:catalog/:itemId",
      "assets": "GET /games/:gameId/playable/:catalog/:itemId/assets",
      "saveAssets": "PATCH /games/:gameId/playable/:catalog/:itemId/assets",
      "export": "GET /games/:gameId/playable/export?type=:catalog",
      "import": "POST /games/:gameId/playable/import"
    },
    "content": {
      "metadata": "GET /metadata",
      "saveMetadata": "PATCH /metadata",
      "saveNews": "POST /news",
      "saveNewsItem": "PATCH /news/:newsId",
      "deleteNewsItem": "DELETE /news/:newsId",
      "saveNotifications": "POST /notifications",
      "saveNotificationItem": "PATCH /notifications/:notificationId",
      "deleteNotificationItem": "DELETE /notifications/:notificationId"
    },
    "support": {
      "listTickets": "GET /support/tickets",
      "publicTicket": "POST /support/public",
      "saveTicket": "PATCH /support/tickets/:ticketId"
    },
    "chat": {
      "listMessages": "local chatMessages filtered by roomId/channelId",
      "sendMessage": "append local chatMessages",
      "events": "http://127.0.0.1:8787/realtime"
    },
    "saves": {
      "list": "GET /users/:userId/saves?gameId=:gameId",
      "save": "PATCH /users/:userId/saves/:saveId"
    },
    "audit": {
      "append": "POST /audit",
      "list": "GET /audit?limit=:limit"
    },
    "backup": {
      "export": "GET /backup/export",
      "import": "POST /backup/import"
    }
  }
}
